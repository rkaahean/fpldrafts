{
  "name": "fpldrafts",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "bootstrap": "npx tsc scripts/bootstrap.ts --outDir build && node build/bootstrap.js",
    "picks": "npx tsc scripts/picks.ts --outDir build && node build/picks.js",
    "elements": "npx tsc scripts/elements.ts --outDir build && node build/elements.js",
    "fixtures": "npx tsc scripts/fixtures.ts --outDir build && node build/fixtures.js",
    "scratchpad": "npx tsc scripts/scratchpad.ts --outDir build && node build/scratchpad.js",
    "update": "npm run bootstrap && npm run picks && npm run elements && npm run fixtures",
    "postinstall": "prisma generate",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/speed-insights": "^1.3.1",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "geist": "^1.7.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-sitemap": "^4.2.3",
    "posthog-js": "^1.404.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.4",
    "bufferutil": "^4.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.1.0",
    "postcss": "^8.5.19",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
